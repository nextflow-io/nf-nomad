def localStackDir = System.getenv("NF_NOMAD_LOCAL_STACK_DIR") ?: "${launchDir}/../../infrastructure/03_automation/035_terraform/local-nomad-minio"
def localWorkDir = System.getenv("NF_NOMAD_LOCAL_WORK_DIR") ?: "${localStackDir}/work"
def localNextflowHome = System.getenv("NF_NOMAD_LOCAL_NXF_HOME") ?: "${System.getenv("HOME")}/.nextflow"
def localNomadAddr = System.getenv("NOMAD_ADDR") ?: "http://localhost:4646"
plugins {
    id "nf-nomad@${System.getenv("NOMAD_PLUGIN_VERSION") ?: "99.99.99"}"
}



aws.client.anonymous = true

process {
    executor = "nomad"
    shell = ['/bin/bash', '-euo', 'pipefail']

    withLabel:process_single {
        cpus = 1
        memory = "2 GB"
        maxForks = 1
        nomadOptions = [
            priority : 'normal',
            resources: [memoryMax: '2 GB'],
            meta     : [suite: 'integration', tier: 'single']
        ]
    }

    withLabel:process_low {
        cpus = 1
        memory = "2 GB"
        maxForks = 2
        nomadOptions = [
            priority : 'low',
            resources: [memoryMax: '2 GB'],
            meta     : [suite: 'integration', tier: 'low']
        ]
    }

    withLabel:process_medium {
        cpus = 1
        memory = "4 GB"
        maxForks = 1
        nomadOptions = [
            priority : 'high',
            resources: [memoryMax: '6 GB'],
            meta     : [suite: 'integration', tier: 'medium']
        ]
    }

    withLabel:process_high {
        cpus = 2
        memory = "8 GB"
        maxForks = 1
        nomadOptions = [
            priority     : 'high',
            shutdownDelay: '10s',
            resources    : [memoryMax: '10 GB'],
            meta         : [suite: 'integration', tier: 'high']
        ]
    }

    withLabel:process_high_memory {
        cpus = 2
        memory = "8 GB"
        maxForks = 1
        nomadOptions = [
            priority : 'critical',
            resources: [memoryMax: '12 GB'],
            failures : [restart: [attempts: 1, mode: 'fail']],
            meta     : [suite: 'integration', tier: 'high-memory']
        ]
    }
}

// nf-nomad-dev workspace
tower {
    workspaceId = "276172789442513"

}

docker {
    enabled = true
}


workDir = localWorkDir


nomad {

    // debug = true

    client {
        address = localNomadAddr
        pollInterval = "2s"
        submitThrottle = "100ms"
    }

    jobs {

        // namespace = 'nf-nomad'

        failOnPlacementFailure = true
        placementFailureTimeout = "2m"
        cleanup = "never"
        deleteOnCompletion = false
        cpuMode = "cores"
        acceleratorAutoDevice = true
        acceleratorDeviceName = "nvidia/gpu"
        meta = [env: 'local-nomadlab', suite: 'integration']
        failures = [
            restart   : [attempts: 1, mode: 'fail'],
            reschedule: [attempts: 1]
        ]
        volumes = [{ type "host" name "work" path "${localWorkDir}/" },
                   { type "host" name "dothome_nextflow" path "${localNextflowHome}/" }]

    }

}
